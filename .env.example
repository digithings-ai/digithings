# Digi Ecosystem – Phase 0+ (February 2026)
# Copy to .env and fill in. Never commit .env.
# See SECURITY.md: bind to 127.0.0.1; use Tailscale/Cloudflare for remote.

# ─── LLM (LiteLLM / DigiGraph) ─────────────────────────────────────
# In Docker, OPENAI_API_BASE is set by compose to http://litellm:4000/v1 (DigiGraph → LiteLLM).
# Model selection: DIGI_LLM_MODE=test|medium|best (default: test for minimal tokens). See config/MODELS.md.
DIGI_LLM_MODE=test
# Local Ollama hostnames (not Ollama Cloud): point DIGI_CONFIG_PATH at repo config and set e.g. model_modes.local.yaml — see docs/LOCAL_STACK.md.
# DIGI_MODEL_MODES_FILE=model_modes.local.yaml
# Free-tier LLM providers — sign up at the URLs below (no credit card required)
# These power the digi/fast, digi/balanced, digi/best, digi/multimodal routes in config/litellm.yaml.
GROQ_API_KEY=       # https://console.groq.com — free tier, 500–1500 tok/s, 128k ctx
CEREBRAS_API_KEY=   # https://cloud.cerebras.ai — free tier, >2000 tok/s (digi/balanced)
OPENROUTER_API_KEY= # https://openrouter.ai — :free model variants, vision via Gemini (digi/best, digi/multimodal)
# Ollama Cloud (free tier): get key at ollama.com/settings/keys. LiteLLM uses it for ollama-cloud/* models.
OLLAMA_API_KEY=
# Override mode: set OLLAMA_MODEL to a specific model (e.g. ollama-cloud/glm-5:cloud) to fix the model.
# OLLAMA_MODEL=ollama-cloud/minimax-m2.5:cloud
# OpenAI (optional): upstream provider key for LiteLLM when routing to gpt-4o / gpt-4o-mini (LiteLLM container).
OPENAI_API_KEY=
# When LiteLLM proxy auth is enabled (LITELLM_MASTER_KEY), set this to the same key DigiGraph should send
# as Bearer (master or virtual key). If unset, DigiGraph falls back to OPENAI_API_KEY (dev stacks without proxy auth).
# LITELLM_PROXY_API_KEY=sk-your-master-or-virtual-key
# Local run (no Docker): OPENAI_API_BASE=http://127.0.0.1:4000/v1

# ─── DigiGraph ─────────────────────────────────────────────────────
# Per-project: use projects/<name>/ folder. See projects/README.md.
# DIGI_PROJECT_CONFIG=./projects/sitaas/config.yaml
DIGIGRAPH_HOST=127.0.0.1
DIGIGRAPH_PORT=8000
# CORS: allow the digichat Vite dev server (port 5174) plus the static website server.
# Extend the list with any other origins (e.g. digithings.ai for production).
# Default (when unset): only http://localhost:3000, http://localhost:8000, http://localhost:11434
DIGI_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000,http://localhost:8000,http://localhost:18000
DIGIQUANT_URL=http://digiquant:8001
# Run storage (session/run JSON + exports): set for visualization_agent, data_prep_agent, etc.
# DIGI_RUN_DATA_DIR=./data/runs
# Base URL for export download links (DigiGraph serves files at GET /files/{path}). Use public URL if behind proxy.
# DIGI_FILES_BASE_URL=http://127.0.0.1:8000

# ─── DigiSearch (RAG, document search for agents) ───────────────────
# Compose / in-container: http://digisearch:8002. Host-native (`make stack-local`): MUST use loopback
# — the hostname `digisearch` does not resolve on your Mac unless you add it to /etc/hosts.
DIGISEARCH_URL=http://digisearch:8002
# DIGISEARCH_URL=http://127.0.0.1:8002
# DIGISEARCH_INDEX=default  # Chroma collection + DigiGraph tool default (set on digigraph + digisearch services in Compose)
# EDGAR dev corpus (docs/LOCAL_STACK.md): after ingest into edgar_dev, set DIGISEARCH_INDEX=edgar_dev for DigiClone RAG
# DIGISEARCH_INDEX=edgar_dev
# Docker Compose: digisearch uses CHROMA_PATH=/data/chroma (persistent volume). For Azure instead, set AZURE_SEARCH_* and adjust mount/env as needed.
# DIGISEARCH_ALLOW_STUB=1   # tests ONLY — in-memory substring indexer (never in production)
# Seeding (make seed-digisearch-local — see docs/LOCAL_STACK.md): dgk_live_ key needs digisearch:ingest.
# DIGISEARCH_SEED_API_KEY=
# DIGISEARCH in Docker: seeds are at /app/digisearch/seeds inside the container.
# DIGISEARCH_SEED_REMOTE_PREFIX=/app/digisearch/seeds
# MCP server (optional): docker compose --profile digisearch-mcp up → http://127.0.0.1:8765/mcp

# Azure AI Search (optional): enables real search when set. Install: pip install digisearch[azure]
# AZURE_SEARCH_ENDPOINT=https://YOUR-SERVICE.search.windows.net
# AZURE_SEARCH_API_KEY=your-admin-api-key
# AZURE_SEARCH_INDEX_NAME=your-index-name
# AZURE_SEARCH_CONTENT_FIELD=content  # optional: field with chunk text (default: content)
# AZURE_SEARCH_KEY_FIELD=id          # optional: document key (default: id)
# AZURE_SEARCH_DOC_ID_FIELD=doc_id  # optional: parent doc id (default: doc_id)

# ─── DigiQuant ─────────────────────────────────────────────────────
# DigiGraph → DigiQuant: in Compose use http://digiquant:8001; on host use http://127.0.0.1:8001
# DIGIQUANT_URL=http://127.0.0.1:8001
DIGIQUANT_HOST=127.0.0.1
DIGIQUANT_PORT=8001
# Set NAUTILUS=0 to build DigiQuant without NautilusTrader (no real backtests).
# NAUTILUS=0
# Local override for export output (Docker sets EXPORT_OUTPUT_DIR=/app/results/exports).
# EXPORT_OUTPUT_DIR=./digiquant/results/exports
# Data dir for backtest OHLCV CSVs ({symbol}.csv). Required for run_backtest. Docker: /app/data.
# DIGIQUANT_DATA_DIR=./digiquant/data

# ─── DigiClaw / Heartbeat (Phase 3) ───────────────────────────────────
# Local run: DIGIGRAPH_URL=http://127.0.0.1:8000 DIGIQUANT_URL=http://127.0.0.1:8001
# AUDIT_LOG_PATH=./digiquant/results/audit/events.jsonl
# REOPTIMIZE_STRATEGY=mean_reversion_tech  # strategy_id for drift check (ADDM stub in v0.1)

# ─── LiteLLM proxy ─────────────────────────────────────────────────
# Default compose config: config/litellm.yaml (no model fallbacks). For Ollama fallbacks use config/litellm.dev.yaml and override the litellm service command in compose.
# Master key (sk-...): required for production-style proxy auth; see DOCKER.md and SECURITY.md.
# LITELLM_MASTER_KEY=
# Optional: Redis URL for shared proxy cache (use with compose profile litellm-cache). Default stack uses local cache in litellm.yaml.
# REDIS_URL=redis://redis:6379

# ─── E2E tests (pytest -m e2e) ───────────────────────────────────────
# E2E_BEARER_TOKEN=eyJ...   # DigiKey JWT with digigraph/digiquant/digisearch scopes

# ─── DigiKey (required for DigiGraph/DigiQuant/DigiSearch protected APIs) ──
# DIGIKEY_DATABASE_URL=sqlite:////data/digikey.db   # or Postgres URL
# Compose defaults JWKS for consumers; override only if needed:
# DIGIKEY_JWKS_URL=http://digikey:8005/.well-known/jwks.json
# DIGIKEY_ISSUER=http://digikey:8005
# DIGIKEY_AUDIENCE=digi-ecosystem
# DIGIKEY_PRIVATE_KEY_PEM=   # production: stable RS256 signing key (multiline PEM)
# DIGIKEY_ALLOW_EPHEMERAL_KEY=1   # Docker default: ephemeral key if PEM unset (JWKS rotates on restart)
# DIGIKEY_ADMIN_TOKEN=   # required for POST /v1/admin/keys
# DIGIKEY_BFF_TOKEN=    # DigiChat → grant_type=bff_session
# Same value as LITELLM_MASTER_KEY (optional): OAuth token JSON includes litellm_proxy_api_key; DigiChat forwards X-LiteLLM-Proxy-Key to DigiGraph. Compose defaults DIGIKEY_LITELLM_PROXY_KEY from LITELLM_MASTER_KEY when unset.
# DIGIKEY_LITELLM_PROXY_KEY=
# DIGIKEY_ALLOW_DEV_GLOBAL=0   # set 1 only on loopback to allow dev_global keys

# ─── DigiChat (optional UI + BFF; start with: make up-digichat) ─────
# Publish on host (default loopback). For phone/LAN testing: DIGICHAT_PUBLISH_HOST=0.0.0.0 — see SECURITY.md.
# DIGICHAT_PUBLISH_HOST=127.0.0.1
# DIGICHAT_PUBLISH_PORT=3005
# Browser origin must match session cookies: AUTH_URL=http://127.0.0.1:3005 (or localhost — pick one consistently).
AUTH_URL=http://127.0.0.1:3005
# AUTH_SECRET=   # required in production (openssl rand -base64 32)
# DIGIKEY_URL=http://127.0.0.1:8005
# DIGIKEY_BFF_TOKEN=   # must match DigiKey service; enables OIDC session exchange
# DIGIGRAPH_UPSTREAM_API_KEY=   # optional static Bearer if not exchanging via DigiKey
# Postgres password for digichat-db service (compose default: digichat).
# DIGICHAT_POSTGRES_PASSWORD=digichat
