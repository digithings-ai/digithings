# Digi Ecosystem – Phase 0+ (February 2026)
# Copy to .env and fill in. Never commit .env.
# See SECURITY.md: bind to 127.0.0.1; use Tailscale/Cloudflare for remote.

# ─── LLM (LiteLLM / DigiGraph) ─────────────────────────────────────
# In Docker, OPENAI_API_BASE is set by compose to http://litellm:4000/v1 (DigiGraph → LiteLLM).
# Model selection: DIGI_LLM_MODE=test|medium|best (default: test for minimal tokens). See config/MODELS.md.
DIGI_LLM_MODE=test
# Ollama Cloud (free tier): get key at ollama.com/settings/keys. LiteLLM uses it for ollama-cloud/* models.
OLLAMA_API_KEY=
# Override mode: set OLLAMA_MODEL to a specific model (e.g. ollama-cloud/glm-5:cloud) to fix the model.
# OLLAMA_MODEL=ollama-cloud/minimax-m2.5:cloud
# OpenAI (optional): set OPENAI_API_KEY for gpt-4o / gpt-4o-mini.
OPENAI_API_KEY=
# Local run (no Docker): OPENAI_API_BASE=http://127.0.0.1:4000/v1
# Optional: LITELLM_MASTER_KEY=, REDIS_URL=redis://redis:6379

# ─── DigiGraph ─────────────────────────────────────────────────────
DIGIGRAPH_HOST=127.0.0.1
DIGIGRAPH_PORT=8000
DIGIQUANT_URL=http://digiquant:8001

# ─── DigiQuant ─────────────────────────────────────────────────────
DIGIQUANT_HOST=127.0.0.1
DIGIQUANT_PORT=8001
# Set NAUTILUS=0 to build DigiQuant without NautilusTrader (no real backtests).
# NAUTILUS=0
# Local override for export output (Docker sets EXPORT_OUTPUT_DIR=/app/results/exports).
# EXPORT_OUTPUT_DIR=./digiquant/results/exports

# ─── DigiClaw / Heartbeat (Phase 3) ───────────────────────────────────
# For local run: DIGIGRAPH_URL=http://127.0.0.1:8000 DIGIQUANT_URL=http://127.0.0.1:8001
# AUDIT_LOG_PATH=./digiquant/results/audit/events.jsonl
# REOPTIMIZE_STRATEGY=mean_reversion_tech  # strategy_id for drift check (ADDM stub in v0.1)

# ─── LiteLLM (optional; Phase 1+) ───────────────────────────────────
# LITELLM_MASTER_KEY=
# REDIS_URL=redis://redis:6379
