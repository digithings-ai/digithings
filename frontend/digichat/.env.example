# Copy to .env.local and use `npm run dev` (port 3000) for fast iteration.
#
# Recommended (no Docker): from repo root run `make stack-local`, then `make digichat-dev` — backends on
# 127.0.0.1:8000–8003,8005 (+ optional LiteLLM :4000). Set DIGIKEY_* below to match root `.env`.
# Alternative: `make up` (Docker backends) — see DIGICHAT.md → Docker Compose / digichat profile.
# After editing, verify: `make digichat-health` (requires `npm run dev` in another terminal).

# Required for Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET=
# Same value as AUTH_SECRET if you set both (avoids JWT decrypt mismatches across tools).
# NEXTAUTH_SECRET=

# Public URL of this app (OAuth callback)
AUTH_URL=http://127.0.0.1:3000
# Same origin as AUTH_URL for dev (Auth.js client); use 127.0.0.1 or localhost consistently.
# NEXTAUTH_URL=http://127.0.0.1:3000

# Trust X-Forwarded-* when behind a reverse proxy
AUTH_TRUST_HOST=true

# Generic OIDC (Auth0, Keycloak, etc.)
AUTH_OIDC_ISSUER=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=

# DigiKey (JWT exchange for DigiGraph + verticals). Required for real chat unless you set DIGIGRAPH_UPSTREAM_API_KEY.
# Must match the same values as repo-root `.env` when using `make stack-local` (DIGIKEY_BFF_TOKEN).
DIGIKEY_URL=http://127.0.0.1:8005
DIGIKEY_BFF_TOKEN=

# DigiGraph (server-side only — never expose to the browser)
DIGIGRAPH_INTERNAL_URL=http://127.0.0.1:8000
DIGIQUANT_INTERNAL_URL=http://127.0.0.1:8001
DIGISMITH_INTERNAL_URL=http://127.0.0.1:8003
# DigiSearch — host stack uses :8002 (see `make stack-local`). For Compose profile digichat use http://digisearch:8002 inside the UI container only.
DIGISEARCH_INTERNAL_URL=http://127.0.0.1:8002
# Ecosystem sheet + health probes for all verticals
DIGICHAT_ENABLED_SERVICES=digigraph,digisearch,digiquant,digismith
# Optional: comma-separated hostnames that override default allowlist for ecosystem URL overrides
# DIGICHAT_ENDPOINT_HOST_ALLOWLIST=digigraph.example.com
DIGIGRAPH_UPSTREAM_API_KEY=

# Match DigiGraph model id (often sitaas-rag for Open WebUI-style tool blocks)
DIGICHAT_MODEL=sitaas-rag

# Set to 0 to omit X-Response-Format: openwebui upstream
DIGICHAT_OPENWEBUI_FORMAT=1

# BFF: forward DigiGraph SSE with digigraph_trace into UI data parts (set to 0 to use legacy streamText-only)
DIGICHAT_TRACE_UI=1
# Client: send X-Digichat-Trace: 1 on chat POST unless set to 0
NEXT_PUBLIC_DIGICHAT_TRACE_UI=1

# Postgres (tenants, machine API key hashes, user→tenant map)
DIGICHAT_DATABASE_URL=postgresql://digichat:digichat@127.0.0.1:5433/digichat

# On container start, run Drizzle migrations (Docker Compose sets this)
DIGICHAT_AUTO_MIGRATE=0

# Optional: single plaintext key for bootstrap / CI (prefer db:create-key in production)
DIGICHAT_BOOTSTRAP_API_KEY=
DIGICHAT_BOOTSTRAP_TENANT_SLUG=default

# Default tenant slug for OIDC users without a user_tenants row
DIGICHAT_DEFAULT_TENANT_SLUG=default

# Dev only: password login (never enable in production)
DIGICHAT_DEV_AUTH=0
DIGICHAT_DEV_PASSWORD=dev
# Dev only: auto sign-in with a real session (openssl rand -hex 24). Server action sends this to Auth.js; never commit a prod value.
# DIGICHAT_LOCAL_AUTH_KEY=
