# Olympus environment — copy to `.env.local` and fill in.
# All client-exposed vars MUST be prefixed NEXT_PUBLIC_.

# ── Core Supabase (Atlas / Hermes data) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: base path when hosted under a sub-path (e.g. /olympus).
# NEXT_PUBLIC_BASE_PATH=
# Optional: footer version label.
# NEXT_PUBLIC_OLYMPUS_VERSION=
# Optional: route snapshot reads through a /api/snapshots BFF instead of anon Supabase.
# NEXT_PUBLIC_OLYMPUS_USE_BFF=1

# ── twelve-x FX Research suite (UNLINKED / gated) ───────────────────────────
# The FX Research suite is hidden by default. Set this to "1" to surface its
# sidebar entry and route (/twelve-x).
# NEXT_PUBLIC_TWELVEX_ENABLED=1

# Dedicated twelve-x Supabase project. When UNSET, the FX fetchers fall back to
# the main NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY above — so a
# shared project needs no extra config. Set these only when twelve-x lives in a
# separate Supabase project.
# NEXT_PUBLIC_TWELVEX_SUPABASE_URL=
# NEXT_PUBLIC_TWELVEX_SUPABASE_ANON_KEY=
