{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "digiquant-atlas Asset Recommendation",
  "description": "Per-ticker analyst report used in deliberation/PM pipeline. JSON source of truth; markdown is derived.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_type", "date", "ticker", "meta", "body"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+$" },
    "doc_type": { "type": "string", "const": "asset_recommendation" },
    "date": { "type": "string", "format": "date" },
    "ticker": { "type": "string", "minLength": 1, "maxLength": 12 },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "analyst"],
      "properties": {
        "name": { "type": ["string", "null"], "maxLength": 200 },
        "category": { "type": "string", "maxLength": 64 },
        "analyst": { "type": "string", "maxLength": 64 },
        "thesis_id": { "type": ["string", "null"], "maxLength": 32 },
        "regime": { "type": ["string", "null"], "maxLength": 200 },
        "linked_thesis_ids": {
          "type": "array",
          "items": { "type": "string", "maxLength": 32 },
          "description": "Track B: tie to market_thesis_exploration thesis_id values (preferred over single thesis_id)."
        },
        "research_citations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_kind", "ref_id"],
            "properties": {
              "ref_kind": {
                "type": "string",
                "enum": ["document_key", "changelog_item", "digest_path", "note"]
              },
              "ref_id": { "type": "string", "maxLength": 512 },
              "note": { "type": "string", "maxLength": 500 }
            }
          }
        },
        "light_research_requested": {
          "type": "boolean",
          "description": "True when PM asked for recess research during deliberation."
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "bull_case", "bear_case", "verdict"],
      "properties": {
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["price", "day_pct", "segment_bias"],
          "properties": {
            "price": { "type": ["number", "null"] },
            "day_pct": { "type": ["number", "null"] },
            "segment_bias": { "type": "string", "maxLength": 32 }
          }
        },
        "bull_case": { "type": "array", "items": { "type": "string", "maxLength": 2000 } },
        "bear_case": { "type": "array", "items": { "type": "string", "maxLength": 2000 } },
        "verdict": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bias", "thesis_status", "recommended_weight_pct", "rationale"],
          "properties": {
            "bias": { "type": "string", "maxLength": 64 },
            "thesis_status": { "type": "string", "maxLength": 64 },
            "entry": { "type": ["string", "null"], "maxLength": 400 },
            "exit": { "type": ["string", "null"], "maxLength": 400 },
            "recommended_weight_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "rationale": { "type": "string", "maxLength": 4000 }
          }
        }
      }
    }
  }
}

