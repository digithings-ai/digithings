{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "digiquant-atlas Evolution Sources",
  "description": "Data source ratings and reuse notes for the pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_type", "date", "title", "body"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+$" },
    "doc_type": { "type": "string", "const": "evolution_sources" },
    "date": { "type": "string", "format": "date" },
    "title": { "type": "string", "maxLength": 200 },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generated_at": { "type": "string", "maxLength": 64 },
        "tags": { "type": "array", "items": { "type": "string", "maxLength": 64 } }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ratings", "notes"],
      "properties": {
        "source_ratings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reliability", "notes"],
            "properties": {
              "name": { "type": "string", "maxLength": 120 },
              "reliability": { "type": "string", "maxLength": 32 },
              "notes": { "type": "string", "maxLength": 2000 }
            }
          }
        },
        "notes": { "type": "string", "maxLength": 8000 }
      }
    }
  }
}
