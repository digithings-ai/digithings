{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "digiquant-atlas Weekly Digest",
  "description": "Weekly synthesis artifact. JSON source of truth; markdown is rendered from this payload.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_type", "date", "week_label", "meta", "body"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+$" },
    "doc_type": { "type": "string", "const": "weekly_digest" },
    "date": { "type": "string", "format": "date", "description": "Week-ending date (YYYY-MM-DD)." },
    "week_label": { "type": "string", "minLength": 3, "maxLength": 40 },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "date_range", "sources"],
      "properties": {
        "generated_at": { "type": "string", "maxLength": 64 },
        "date_range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "string", "format": "date" },
            "end": { "type": "string", "format": "date" }
          }
        },
        "sources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baseline_date", "delta_dates"],
          "properties": {
            "baseline_date": { "type": ["string", "null"], "format": "date" },
            "delta_dates": { "type": "array", "items": { "type": "string", "format": "date" } }
          }
        },
        "tags": { "type": "array", "items": { "type": "string", "maxLength": 64 } },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string", "maxLength": 120 },
              "url": { "type": "string", "maxLength": 2000 }
            }
          }
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executive_summary", "daily_bias_shifts", "regime_summary", "asset_class_summary", "thesis_review", "next_week_setup", "key_takeaway"],
      "properties": {
        "executive_summary": { "type": "string", "maxLength": 8000 },
        "daily_bias_shifts": {
          "type": "array",
          "description": "Ordered from baseline through Fri. One row per day.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "date", "macro", "equities", "crypto", "bonds", "key_catalyst"],
            "properties": {
              "label": { "type": "string", "maxLength": 24 },
              "date": { "type": ["string", "null"], "format": "date" },
              "macro": { "type": "string", "maxLength": 32 },
              "equities": { "type": "string", "maxLength": 32 },
              "crypto": { "type": "string", "maxLength": 32 },
              "bonds": { "type": "string", "maxLength": 32 },
              "key_catalyst": { "type": "string", "maxLength": 200 }
            }
          }
        },
        "regime_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["growth", "inflation", "policy", "risk_appetite", "net_change"],
          "properties": {
            "growth": { "$ref": "#/$defs/regimeFactorRow" },
            "inflation": { "$ref": "#/$defs/regimeFactorRow" },
            "policy": { "$ref": "#/$defs/regimeFactorRow" },
            "risk_appetite": { "$ref": "#/$defs/regimeFactorRow" },
            "net_change": { "type": "string", "maxLength": 800 }
          }
        },
        "asset_class_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["equities", "crypto", "bonds", "commodities", "forex"],
          "properties": {
            "equities": { "$ref": "#/$defs/assetClassNarrative" },
            "crypto": { "$ref": "#/$defs/assetClassNarrative" },
            "bonds": { "$ref": "#/$defs/assetClassNarrative" },
            "commodities": { "$ref": "#/$defs/assetClassNarrative" },
            "forex": { "$ref": "#/$defs/assetClassNarrative" }
          }
        },
        "thesis_review": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["thesis_id", "thesis", "weekly_evidence", "status_change"],
            "properties": {
              "thesis_id": { "type": "string", "maxLength": 32 },
              "thesis": { "type": "string", "maxLength": 200 },
              "weekly_evidence": { "type": "string", "maxLength": 2000 },
              "status_change": { "type": "string", "maxLength": 120 }
            }
          }
        },
        "next_week_setup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["key_events", "heading_in_bias", "primary_watch", "positions_to_review"],
          "properties": {
            "key_events": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["day", "date", "event", "why_it_matters"],
                "properties": {
                  "day": { "type": "string", "maxLength": 12 },
                  "date": { "type": ["string", "null"], "format": "date" },
                  "event": { "type": "string", "maxLength": 240 },
                  "why_it_matters": { "type": "string", "maxLength": 400 }
                }
              }
            },
            "heading_in_bias": { "type": "string", "maxLength": 1200 },
            "primary_watch": { "type": "string", "maxLength": 400 },
            "positions_to_review": { "type": "array", "items": { "type": "string", "maxLength": 12 } }
          }
        },
        "key_takeaway": { "type": "string", "maxLength": 1200 },
        "full_document_markdown": {
          "type": ["string", "null"],
          "maxLength": 500000,
          "description": "Optional: legacy weekly markdown preserved during migration; renderer may prefer this for display."
        }
      }
    }
  },
  "$defs": {
    "regimeFactorRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "friday", "weekly_shift"],
      "properties": {
        "baseline": { "type": "string", "maxLength": 120 },
        "friday": { "type": "string", "maxLength": 120 },
        "weekly_shift": { "type": "string", "maxLength": 120 }
      }
    },
    "assetClassNarrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weekly_bias", "highlights"],
      "properties": {
        "weekly_bias": { "type": "string", "maxLength": 64 },
        "highlights": { "type": "string", "maxLength": 6000 },
        "tables": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}

