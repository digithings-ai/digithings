{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "digiquant-atlas Thesis Vehicle Map",
  "description": "Maps market theses to candidate ETF/vehicle tickers using user mandate and watchlist. Multiple vehicles per thesis allowed.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "doc_type", "date", "meta", "body"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1\\.[0-9]+$" },
    "doc_type": { "type": "string", "const": "thesis_vehicle_map" },
    "date": { "type": "string", "format": "date" },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_exploration_key"],
      "properties": {
        "source_exploration_key": {
          "type": "string",
          "maxLength": 512,
          "description": "documents.document_key for market_thesis_exploration for this date."
        },
        "user_mandate_notes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1500 }
        }
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mappings"],
      "properties": {
        "mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["thesis_id", "candidate_tickers"],
            "properties": {
              "thesis_id": { "type": "string", "maxLength": 32 },
              "candidate_tickers": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "maxLength": 12 }
              },
              "rationale": { "type": "string", "maxLength": 4000 },
              "exclusion_reasons": {
                "type": "array",
                "items": { "type": "string", "maxLength": 800 }
              },
              "user_mandate_notes": {
                "type": "array",
                "items": { "type": "string", "maxLength": 800 }
              }
            }
          }
        }
      }
    }
  }
}
