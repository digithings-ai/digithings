# Digi Ecosystem – root .gitignore

# Claude Code agent worktrees (ephemeral copies; do not commit)
.claude/worktrees/
/.worktrees/

# Local Claude Code overrides (tokens, paths — never commit)
.claude/settings.local.json

# Claude Code runtime state (scheduler lock, transient)
.claude/scheduled_tasks.lock

# Stray npm installs at repo root — always use workspace-scoped installs under frontend/
/node_modules/

.venv/
.venv-ci/
venv/
.env
projects/*/.env

# Confidential: project configs and deployments (never share)
# Anchored to repo root so docs/projects/ (public dogfooding projects) is not captured.
# Allowlist projects/README.md only (private-repo pointer index).
/projects/*
!/projects/README.md
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/
dist/
build/
.cache/

# Runtime results (exports, audit logs) – recreated on run
digiquant/results/

# Repo-root runtime caches (Atlas price-history, agent-cache paths) — JAN-004
/data/

# Local agent memory archives (Cursor/agent tooling) — JAN-005
.remember/

# Local DigiKey dev SQLite (run_stack_local.sh) — JAN-006
.local_digikey.sqlite
/*.sqlite

# Olympus static portfolio fallback — stop tracking after REM-037 (JAN-007)
frontend/olympus/public/dashboard-data.json


# Secrets and credentials
.env*
projects/*/.env*
secrets.yaml
digikey/examples/vault.yaml

# Local stack (scripts/run_stack_local.sh)
.local_stack_pids
.litellm-local.log

# Log files
*.log

# Large data files and caches (CSV, Parquet, pickles)
# note: sample data in repo may be checked in intentionally, but user-owned
# datasets should not be
**/data/*.csv
**/data/*.parquet
**/data/*.pkl
**/data/*.pickle
**/data/*/*.csv
**/data/*/*.parquet
**/data/*/*.pkl
**/data/*/*.pickle

# Packaging output
digi-bundle-*.tar.gz
.DS_Store

# DigiGraph ECharts (installed in Docker / local npm ci; do not vendor node_modules)
digigraph/src/digigraph/tools/analytics/visualization/echarts/node_modules/

# DigiSearch EDGAR dev exports (generated; keep devdata/edgar_sample/.gitkeep)
digisearch/devdata/edgar_sample/edgar_*.md
digisearch/devdata/edgar_sample/edgar_*.yaml

# Local SQLite databases
*.sqlite

# Coverage artifacts
htmlcov/
.coverage
.coverage.*
coverage.xml

# macOS
.DS_Store
**/.DS_Store

# Editor / tooling
.vscode/
.idea/
*.bak

# DesignSync local tooling output (node_modules, bundles, screenshots, canvases — generated)
.ds-sync/
ds-bundle/
canvases/

# Strategy calibrations — proprietary tuning values
**/calibrations.json
# Strategy Pine files embed calibrated inputs (input.int(70, ...)) — keep private.
# The indicator library (pinescript/indicators/*.pine) is calibration-free and is
# committed as reusable fallback code.
**/pinescript/*.pine

# Private client projects — never commit
docs/projects/sitaas/
# (Top-level /projects/ is anchored earlier in this file — do not add an
# unanchored `projects/` rule here, it would also capture docs/projects/.)
